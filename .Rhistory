source("data-raw/generate_sim_data.R")  # creates data/sim_mediation.rda
devtools::document()    # regenerates man/ pages and NAMESPACE
devtools::load_all(".")  # loads the package in-place
data(sim_mediation)
fit <- robustmediate(
X ~ Z1 + Z2 + Z3,
M ~ X + Z1 + Z2 + Z3,
Y ~ X + M + Z1 + Z2 + Z3,
data = sim_mediation,
R    = 500
)
# Plots
plot(fit)                        # dose-response curve
plot(fit, type = "balance")      # love plot
plot(fit, type = "sensitivity")  # E-value × rho contour
plot(fit, type = "itcv")         # Frank's ITCV corridor
plot(fit, type = "mitcv")        # mITCV robustness profile
# Reports
diagnose(fit)                    # full sensitivity report
print(fit$mitcv)                 # mITCV with publishable language
fragility_table(fit)             # Table 2 for your paper
devtools::test()
devtools::document()    # regenerates man/ pages and NAMESPACE
devtools::load_all(".")  # loads the package in-place
devtools::load_all(".")  # loads the package in-place
data(sim_mediation)
fit <- robustmediate(
X ~ Z1 + Z2 + Z3,
M ~ X + Z1 + Z2 + Z3,
Y ~ X + M + Z1 + Z2 + Z3,
data = sim_mediation,
R    = 500
)
# Plots
plot(fit)                        # dose-response curve
plot(fit, type = "balance")      # love plot
plot(fit, type = "sensitivity")  # E-value × rho contour
plot(fit, type = "itcv")         # Frank's ITCV corridor
plot(fit, type = "mitcv")        # mITCV robustness profile
plot(fit, type = "curvature")    # dose-varying fragility
# Reports
diagnose(fit)                    # full sensitivity report
print(fit$mitcv)                 # mITCV with publishable language
fragility_table(fit)             # Table 2 for your paper
devtools::test()
devtools::check()
data(sim_mediation)
fit <- robustmediate(
X ~ Z1 + Z2 + Z3,
M ~ X + Z1 + Z2 + Z3,
Y ~ X + M + Z1 + Z2 + Z3,
data = sim_mediation,
R = 500
)
# Plots
plot(fit)                           # dose-response curve
plot(fit, type = "balance")         # dual love plot
plot(fit, type = "sensitivity")     # E-value × rho contour
plot(fit, type = "meditcv")         # pathway-specific medITCV corridor
plot(fit, type = "mitcv")           # mITCV robustness profile
plot(fit, type = "curvature")       # dose-varying fragility
# Reports
diagnose(fit)                       # full diagnostic report
print(fit$meditcv)                  # medITCV with pathway-specific interpretation
print(fit$mitcv)                    # mITCV with publishable language
fragility_table(fit)                # pathway fragility summary table
# Plots
plot(fit)                           # dose-response curve
plot(fit, type = "balance")         # dual love plot
plot(fit, type = "sensitivity")     # E-value × rho contour
plot(fit, type = "meditcv")         # pathway-specific medITCV corridor
plot(fit, type = "meditcv")           # medITCV robustness profile
plot(fit, type = "curvature")       # dose-varying fragility
# Reports
diagnose(fit)                       # full diagnostic report
print(fit$meditcv)                    # mITCV with publishable language
print(fit$meditcv)
fragility_table(fit)                # pathway fragility summary table
devtools::document()    # regenerates man/ pages and NAMESPACE
devtools::load_all(".")  # loads the package in-place
devtools::test()
devtools::check()
devtools::document()    # regenerates man/ pages and NAMESPACE
devtools::check()
tools::showNonASCIIfile("R/diagnose.R")
tools::showNonASCIIfile("R/methods.R")
tools::showNonASCIIfile("R/RobustMediate-package.R")
devtools::document()    # regenerates man/ pages and NAMESPACE
devtools::check()
