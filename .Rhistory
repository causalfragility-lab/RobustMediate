data(sim_mediation)
set.seed(42)
fit <- robustmediate(
X ~ Z1+Z2+Z3, M ~ X+Z1+Z2+Z3, Y ~ X+M+Z1+Z2+Z3,
data = sim_mediation, R = 200, verbose = TRUE
)
cat("\n── Bootstrap diagnostic ─────────────────────────────\n")
cat("Valid replicates:", fit$effects$n_boot_valid, "/ 200\n")
cat("\n── Effects with CIs ─────────────────────────────────\n")
cat(sprintf("NDE: %+.4f  [%.4f, %.4f]\n",
fit$effects$summary$NDE,
fit$effects$summary$NDE_lo,
fit$effects$summary$NDE_hi))
cat(sprintf("NIE: %+.4f  [%.4f, %.4f]\n",
fit$effects$summary$NIE,
fit$effects$summary$NIE_lo,
fit$effects$summary$NIE_hi))
cat(sprintf("TE:  %+.4f  [%.4f, %.4f]\n",
fit$effects$summary$TE,
fit$effects$summary$TE_lo,
fit$effects$summary$TE_hi))
cat(sprintf("%% mediated: %.1f%%\n", fit$effects$summary$pct_mediated))
# ── Step 5: Re-run simulation ─────────────────────────────────────────────────
cat("\n── Simulation test (50 reps, fast check) ────────────\n")
set.seed(2026)
n_sims <- 50; n <- 300
results <- data.frame(
NDE=numeric(n_sims), NIE=numeric(n_sims),
NDE_lo=numeric(n_sims), NDE_hi=numeric(n_sims),
NIE_lo=numeric(n_sims), NIE_hi=numeric(n_sims),
ci_covers_NDE=logical(n_sims), ci_covers_NIE=logical(n_sims),
converged=logical(n_sims)
)
for (s in 1:n_sims) {
if (s %% 10 == 0) cat("  Sim", s, "\n")
Z1 <- rnorm(n); Z2 <- rbinom(n,1,0.5)
X  <- 0.5*Z1 + 0.3*Z2 + rnorm(n)
M  <- 0.4*X  + 0.2*Z1 + rnorm(n)
Y  <- 0.3*X  + 0.5*M  + 0.2*Z1 + rnorm(n)
f  <- tryCatch(
robustmediate(X~Z1+Z2, M~X+Z1+Z2, Y~X+M+Z1+Z2,
data=data.frame(Y,X,M,Z1,Z2), R=100, verbose=FALSE),
error = function(e) NULL)
if (is.null(f)) next
s_nde    <- f$effects$summary
results[s,] <- list(
s_nde$NDE, s_nde$NIE,
s_nde$NDE_lo, s_nde$NDE_hi,
s_nde$NIE_lo, s_nde$NIE_hi,
(!is.na(s_nde$NDE_lo) && s_nde$NDE_lo <= 0.30 && s_nde$NDE_hi >= 0.30),
(!is.na(s_nde$NIE_lo) && s_nde$NIE_lo <= 0.20 && s_nde$NIE_hi >= 0.20),
TRUE
)
}
d <- results[results$converged,]
cat(sprintf("\nConverged: %d / %d\n", nrow(d), n_sims))
cat(sprintf("CIs are non-NA: NDE=%d%%  NIE=%d%%\n",
round(100*mean(!is.na(d$NDE_lo))),
round(100*mean(!is.na(d$NIE_lo)))))
cat(sprintf("95%% CI coverage: NDE=%.1f%%  NIE=%.1f%%\n",
100*mean(d$ci_covers_NDE, na.rm=TRUE),
100*mean(d$ci_covers_NIE, na.rm=TRUE)))
cat(sprintf("NDE Mean=%.4f  Bias=%.4f\n", mean(d$NDE), mean(d$NDE)-0.30))
cat(sprintf("NIE Mean=%.4f  Bias=%.4f\n", mean(d$NIE), mean(d$NIE)-0.20))
cat("\n══════════════════════════════════════════════════════\n")
cat("If CIs are non-NA and coverage ~85-95% — bootstrap is FIXED\n")
cat("══════════════════════════════════════════════════════\n")
